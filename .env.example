# .env.example — copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────
# STEP 1: Choose your embedding provider
#   Options: google | sentence_transformers 
# ─────────────────────────────────────────────────────────────────────────────
EMBEDDING_PROVIDER=google

# ── Option A: Google (free) ────────────────────────────────────────────────
GOOGLE_API_KEY=AIza...
EMBEDDING_MODEL=gemini-embedding-004
EMBEDDING_DIMENSION=768
LLM_PROVIDER=google
LLM_MODEL=gemini-2.5-flash-preview-04-17

# ── Option C: Groq (for LLM generation) ────────────────────────────────────
# LLM_PROVIDER=groq
# GROQ_API_KEY=gsk_...
# LLM_MODEL=llama-3.3-70b-versatile  ← automatically set in code

# ── Option B: Sentence Transformers (local, free, no API key) ──────────────
# EMBEDDING_PROVIDER=sentence_transformers
# EMBEDDING_MODEL=all-MiniLM-L6-v2
# EMBEDDING_DIMENSION=384
# LLM_PROVIDER=google           ← still use Gemini for generation
# LLM_MODEL=gemini-2.5-flash-preview-04-17
# GOOGLE_API_KEY=AIza...

# ─────────────────────────────────────────────────────────────────────────────
# Pinecone (required for all options)
# ─────────────────────────────────────────────────────────────────────────────
PINECONE_API_KEY=pcsk-...
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=rag-documents

# ─────────────────────────────────────────────────────────────────────────────
# General settings
# ─────────────────────────────────────────────────────────────────────────────
PDF_DIR=./pdfs
CHUNK_SIZE=800
CHUNK_OVERLAP=100
TOP_K=5
LOG_LEVEL=INFO
QUIET_THIRD_PARTY_LOGS=true

# ─────────────────────────────────────────────────────────────────────────────
# LangSmith tracing (optional)
# ─────────────────────────────────────────────────────────────────────────────
# Create a key at https://smith.langchain.com, then set tracing to true.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=rag-pipeline
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
