# ── Required secrets ──────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=rag-index
LANGCHAIN_API_KEY=ls__...          # optional — disables LangSmith tracing if blank

# ── Model configuration ───────────────────────────────────────────────────────
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048
LLM_MAX_RETRIES=3

EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ── Pinecone ──────────────────────────────────────────────────────────────────
PINECONE_ENVIRONMENT=us-east-1

# ── Retrieval ─────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.3
DEFAULT_NAMESPACES=["ESDM","cement"]

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── LangSmith ─────────────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=rag-system
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# ── Prompt (optional override) ────────────────────────────────────────────────
# Leave blank to use the default: prompts/Sector_analysis_prompt.yaml
SECTOR_PROMPT_PATH=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
